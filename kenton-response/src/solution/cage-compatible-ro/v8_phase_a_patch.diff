+// See src/heap/shared-ro-slab.h.
+DEFINE_BOOL(shared_ro_heap_via_memfd, false,
+            "enable cage-compatible process-wide shared ReadOnly slab "
+            "via memfd. Linux-only. EXPERIMENTAL.")
+
 // Flags for stack switching
