diff --git a/src/heap/shared-ro-slab.h b/src/heap/shared-ro-slab.h
new file mode 100644
--- /dev/null
+++ b/src/heap/shared-ro-slab.h
@@ -0,0 +1,86 @@
+// Copyright 2026 the V8 project authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can
+// be found in the LICENSE file.
+//
+// Process-wide ReadOnly slab backed by memfd, mappable at identical
+// intra-cage offsets in every isolate cage. See DESIGN.md in the
+// kenton-response repo for the rationale and the standalone Linux
+// prototype that validates the approach.
+
+#ifndef V8_HEAP_SHARED_RO_SLAB_H_
+#define V8_HEAP_SHARED_RO_SLAB_H_
+
+#include <atomic>
+#include <cstddef>
+#include <cstdint>
+
+#include "src/base/platform/mutex.h"
+#include "src/common/globals.h"
+
+namespace v8 {
+namespace internal {
+
+class SnapshotData;
+
+// Owns the process-wide read-only slab for cage-compatible shared
+// ReadOnlyHeap. Linux-only initially (uses memfd_create + MAP_FIXED).
+class V8_EXPORT_PRIVATE SharedRoSlab {
+ public:
+  // Initialise the slab from the RO portion of the startup snapshot.
+  // Idempotent; safe to call from multiple isolates concurrently.
+  // Returns true on success, false if the platform doesn't support
+  // the required mechanism (non-Linux, or kernel older than 3.17).
+  static bool EnsureInitialized(const SnapshotData* ro_snapshot_data);
+
+  // Attach the slab into the given cage. Must be called immediately
+  // after a 4 GB-aligned cage region is reserved (PROT_NONE), before
+  // V8 commits any pages within the slab's range.
+  //
+  // Idempotent per-cage: re-attach to the same cage_base is a no-op.
+  // Returns true on success.
+  //
+  // SHARED-RO-TODO: error path here is fatal because by the time we
+  // attach, the cage allocator has already publicly reserved
+  // [cage_base, cage_base + 4 GB). Falling back to per-cage RO space
+  // requires teaching the allocator to retry without our flag — left
+  // for a follow-up.
+  static bool AttachToCage(Address cage_base);
+
+  // The intra-cage offset and size of the slab. Compressed pointer
+  // values in [0, size()) decode to slab contents.
+  static size_t Size();
+  static size_t Offset();  // currently always 0
+
+  // True iff the slab is up and successfully attached to at least
+  // one cage. Used by IsReadOnlySpaceShared() at runtime.
+  static bool IsActive();
+
+  // Test-only: tear everything down. Production code never calls this.
+  static void TearDownForTesting();
+
+ private:
+  SharedRoSlab() = delete;
+
+  static void PopulateFromSnapshot(void* writable_mapping,
+                                   const SnapshotData* ro_snapshot_data);
+  static int CreateMemfd();
+
+  static std::atomic<bool> initialized_;
+  static std::atomic<bool> active_;
+  static int fd_;
+  static size_t slab_size_;
+  static v8::base::Mutex init_mutex_;
+};
+
+}  // namespace internal
+}  // namespace v8
+
+#endif  // V8_HEAP_SHARED_RO_SLAB_H_

diff --git a/src/heap/shared-ro-slab.cc b/src/heap/shared-ro-slab.cc
new file mode 100644
--- /dev/null
+++ b/src/heap/shared-ro-slab.cc
@@ -0,0 +1,138 @@
+// Copyright 2026 the V8 project authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can
+// be found in the LICENSE file.
+
+#include "src/heap/shared-ro-slab.h"
+
+#include "src/base/platform/mutex.h"
+#include "src/common/globals.h"
+#include "src/flags/flags.h"
+#include "src/snapshot/snapshot-data.h"  // SnapshotData (complete type)
+
+#if V8_OS_LINUX
+#include <errno.h>
+#include <fcntl.h>
+#include <linux/memfd.h>
+#include <string.h>
+#include <sys/mman.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+#endif
+
+namespace v8 {
+namespace internal {
+
+std::atomic<bool> SharedRoSlab::initialized_{false};
+std::atomic<bool> SharedRoSlab::active_{false};
+int SharedRoSlab::fd_ = -1;
+size_t SharedRoSlab::slab_size_ = 0;
+v8::base::Mutex SharedRoSlab::init_mutex_;
+
+namespace {
+
+#if V8_OS_LINUX
+// Round up to the page size; the slab must be a multiple of pages.
+constexpr size_t kPageSize = 4096;
+constexpr size_t RoundUpToPage(size_t n) {
+  return (n + kPageSize - 1) & ~(kPageSize - 1);
+}
+#endif
+
+}  // namespace
+
+bool SharedRoSlab::EnsureInitialized(const SnapshotData* ro_snapshot_data) {
+  if (initialized_.load(std::memory_order_acquire)) return active_.load();
+#if !V8_OS_LINUX
+  // SHARED-RO-TODO: macOS via shm_open, Windows via CreateFileMapping.
+  initialized_.store(true, std::memory_order_release);
+  return false;
+#else
+  v8::base::MutexGuard lock(&init_mutex_);
+  if (initialized_.load(std::memory_order_relaxed)) return active_.load();
+
+  if (!v8_flags.shared_ro_heap_via_memfd) {
+    initialized_.store(true, std::memory_order_release);
+    return false;
+  }
+  if (!ro_snapshot_data) {
+    initialized_.store(true, std::memory_order_release);
+    return false;
+  }
+
+  size_t want_size = RoundUpToPage(ro_snapshot_data->Payload().size());
+  int fd = CreateMemfd();
+  if (fd < 0) {
+    initialized_.store(true, std::memory_order_release);
+    return false;
+  }
+  if (ftruncate(fd, want_size) != 0) {
+    close(fd);
+    initialized_.store(true, std::memory_order_release);
+    return false;
+  }
+
+  // Populate via a writable mapping, then drop it.
+  void* w = mmap(nullptr, want_size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+  if (w == MAP_FAILED) {
+    close(fd);
+    initialized_.store(true, std::memory_order_release);
+    return false;
+  }
+  PopulateFromSnapshot(w, ro_snapshot_data);
+  msync(w, want_size, MS_SYNC);
+  munmap(w, want_size);
+
+  // SHARED-RO-TODO: F_SEAL_WRITE here in production. Skipped under
+  // certain container sandbox configs that EPERM the resulting
+  // MAP_FIXED. The PROT_READ flag on every per-cage mapping is the
+  // primary RO guarantee; the seal is defense-in-depth.
+
+  fd_ = fd;
+  slab_size_ = want_size;
+  active_.store(true, std::memory_order_release);
+  initialized_.store(true, std::memory_order_release);
+  return true;
+#endif  // V8_OS_LINUX
+}
+
+bool SharedRoSlab::AttachToCage(Address cage_base) {
+  if (!active_.load(std::memory_order_acquire)) return false;
+#if !V8_OS_LINUX
+  return false;
+#else
+  void* p = mmap(reinterpret_cast<void*>(cage_base), slab_size_, PROT_READ,
+                 MAP_FIXED | MAP_SHARED, fd_, 0);
+  if (p == MAP_FAILED || reinterpret_cast<Address>(p) != cage_base) {
+    return false;
+  }
+  return true;
+#endif
+}
+
+size_t SharedRoSlab::Size() { return slab_size_; }
+size_t SharedRoSlab::Offset() { return 0; }
+bool SharedRoSlab::IsActive() {
+  return active_.load(std::memory_order_acquire);
+}
+
+int SharedRoSlab::CreateMemfd() {
+#if V8_OS_LINUX
+  return static_cast<int>(
+      syscall(__NR_memfd_create, "v8_shared_ro_slab", MFD_CLOEXEC));
+#else
+  return -1;
+#endif
+}
+
+void SharedRoSlab::PopulateFromSnapshot(
+    void* mapping, const SnapshotData* ro_snapshot_data) {
+  // SHARED-RO-TODO: this is a placeholder. Real impl deserialises the
+  // RO snapshot directly into the mapping using a slab-targeted
+  // variant of `Deserializer<Isolate>::DeserializeIntoHeap`. For the
+  // skeleton patch we copy the raw payload bytes — sufficient for
+  // the build to compile and the AttachToCage path to be exercised.
+  base::Vector<const uint8_t> payload = ro_snapshot_data->Payload();
+  memcpy(mapping, payload.begin(), payload.size());
+}
+
+void SharedRoSlab::TearDownForTesting() {
+#if V8_OS_LINUX
+  if (fd_ >= 0) close(fd_);
+#endif
+  fd_ = -1;
+  slab_size_ = 0;
+  active_.store(false, std::memory_order_release);
+  initialized_.store(false, std::memory_order_release);
+}
+
+}  // namespace internal
+}  // namespace v8

diff --git a/src/init/isolate-allocator.cc b/src/init/isolate-allocator.cc
--- a/src/init/isolate-allocator.cc
+++ b/src/init/isolate-allocator.cc
@@ -XXXX,6 +XXXX,7 @@
 #include "src/common/ptr-compr-inl.h"
