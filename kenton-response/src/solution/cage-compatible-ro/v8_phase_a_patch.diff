 #include "src/heap/code-range.h"
+#include "src/heap/shared-ro-slab.h"
 #include "src/sandbox/sandbox.h"

 namespace v8 {
@@ -XXXX,6 +XXXX,23 @@ Address IsolateAllocator::InitReservation() {
   //  ... existing 4 GB cage reservation code ...
   //  At this point `cage_base_` holds the start of the 4 GB region,
   //  reserved with PROT_NONE; nothing has been committed inside it yet.
+
+  // SHARED-RO-HOOK: if the cage-compatible shared RO slab is active,
+  // overlay it at offset 0 of this cage. This is harmless even if
+  // V8_COMPRESS_POINTERS_IN_SHARED_CAGE is also set (idempotent
+  // attach). The mapping is PROT_READ; any V8 attempt to commit
+  // writable pages inside the slab's range MUST go through this path
+  // first so we know not to clobber it.
+  //
+  // SHARED-RO-TODO: integrate with PageInitializationMode so the
+  // ReadOnlyHeap allocator skips its own commit when the slab is
+  // active. Currently the allocator would happily try to commit on
+  // top of the slab — needs a guard.
+  if (v8_flags.shared_ro_heap_via_memfd && SharedRoSlab::IsActive()) {
+    if (!SharedRoSlab::AttachToCage(cage_base_)) {
+      FATAL("SharedRoSlab::AttachToCage failed for cage 0x%lx",
+            static_cast<unsigned long>(cage_base_));
+    }
+  }
   ...
 }

diff --git a/src/heap/read-only-heap.h b/src/heap/read-only-heap.h
--- a/src/heap/read-only-heap.h
+++ b/src/heap/read-only-heap.h
@@ -XXXX,12 +XXXX,20 @@ class ReadOnlyHeap {
   // Returns whether the ReadOnlySpace will actually be shared taking into
   // account whether shared memory is available with pointer compression.
-  static constexpr bool IsReadOnlySpaceShared() {
+  static bool IsReadOnlySpaceShared() {
+    // Cage-compatible shared RO heap (via memfd) decouples sharing
+    // from cage-sharing. See SharedRoSlab and shared_ro_heap_via_memfd.
+    if (SharedRoSlab::IsActive()) return true;
     return V8_SHARED_RO_HEAP_BOOL &&
            (!COMPRESS_POINTERS_BOOL || COMPRESS_POINTERS_IN_SHARED_CAGE_BOOL);
   }

diff --git a/src/flags/flag-definitions.h b/src/flags/flag-definitions.h
--- a/src/flags/flag-definitions.h
+++ b/src/flags/flag-definitions.h
@@ -XXXX,6 +XXXX,14 @@ DEFINE_BOOL(use_ic, true, "use inline caching")
+
+// Cage-compatible shared ReadOnly slab via memfd_create + MAP_FIXED.
+// When on, the RO snapshot is deserialised into a process-wide memfd
